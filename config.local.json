{
  // Ollama generate endpoint used by evaluators/evaluate-scene.mjs.
  // Typical local value: "http://localhost:11434/api/generate".
  "ollamaUrl": "http://localhost:11434/api/generate",

  // Ollama model name to use for every evaluator call.
  // Example options depend on what is installed locally: "qwen2.5:7b", "llama3.1:8b", etc.
  "model": "qwen2.5:7b",

  "standardMetrics": {
    "default": {
      // Controls whether non-awareness evaluators store rationale text.
      // "off": store only bounded numeric fields.
      // "extractive": store only exact evidence excerpts copied from supplied scene/definitions.
      // "paraphrase": store one tight model-written rationale sentence.
      "rationaleMode": "paraphrase",

      // Source buckets allowed for extractive evidence validation.
      // Available values: "scene", "definitions".
      "rationaleSources": ["scene", "definitions"],

      // Frontmatter field used for paraphrased rationale on standard metric score objects.
      // Existing reports expect "sceneRationale".
      "rationaleField": "sceneRationale"
    },

    // Per-metric wording for the configured rationale field.
    // These labels are prompt guidance only; the JSON field is controlled by rationaleField above.
    "metrics": {
      "Relevance": { "rationaleType": "relevance rationale" },
      "Tension": { "rationaleType": "tension rationale" },
      "Resolution": { "rationaleType": "resolution rationale" },
      "Pacing": { "rationaleType": "pacing rationale" },
      "Conflict": { "rationaleType": "conflict rationale" },
      "Poetics": { "rationaleType": "poetics rationale" },
      "Coherence": { "rationaleType": "coherence rationale" }
    }
  },

  "scheduler": {
    // How jobs are picked up after Templater queues them.
    // "manual": Templater queues a job and starts a worker that drains the queue, then exits.
    // "background": Templater only queues jobs; a separately started --watch worker polls for work.
    "mode": "background",

    // Directory for job files, logs, cancel markers, and the worker lock.
    // Relative paths are resolved from the obsidianTools folder; absolute paths are allowed.
    "queueDir": ".queue",

    // Delay between evaluator calls. Increase this if Ollama or the machine is overloaded.
    // Lower values run faster but put more pressure on local resources.
    "throttleMs": 1000,

    // Background-mode poll interval. Only used by worker.mjs --watch / scheduler mode "background".
    "pollIntervalMs": 30000,

    // In manual mode, start a detached worker from the Batch-Evaluate-Scenes Templater command.
    // Set false if you want Templater to queue only and you will run worker.mjs --drain yourself.
    "launchWorkerFromTemplater": true,

    // Show periodic Obsidian notices while the queued job is running.
    // Set false if you prefer to watch .queue/logs or job JSON files directly.
    "monitorFromTemplater": true,

    // How often Obsidian checks job progress and shows a notice while monitoring.
    // Notices are only shown when the message changes.
    "statusNoticeIntervalMs": 5000,

    // Safety cap for Obsidian-side monitoring. The worker keeps running after this; notices stop.
    "statusNoticeMaxMinutes": 240,

    // Node executable used by Templater when it shells out to scheduler scripts.
    // Use a full path here if Obsidian cannot find "node" on PATH.
    "nodePath": "/Users/ian/.nvm/versions/node/v22.12.0/bin/node",

    // What Storyboard should do after saving a changed tile order.
    // "manual": only save chapter_order and scene_order; use Queue-Reader-Awareness manually.
    // "ask": ask whether to queue Reader Awareness after saving order.
    // "auto": queue Reader Awareness immediately after saving order.
    "storyboardReaderAwarenessAfterReorder": "ask",

    // Evaluations used by the dedicated Reader Awareness trigger.
    // Full batch also includes these entries as part of scheduler.evaluations below.
    "readerAwarenessEvaluations": [
      ["Reader Awareness", "Character"],
      ["Reader Awareness", "Plot Thread"],
      ["Reader Awareness", "Arc"]
    ],

    // Evaluations to run for each scene, in order.
    // Format: [metric, target].
    // Metric options: "Relevance", "Tension", "Resolution", "Pacing", "Conflict", "Poetics",
    // "Coherence", "Character Awareness", "Reader Awareness".
    // Target options: "Character", "Plot Thread", "Story Engine", "Arc", "Scene".
    // "Pacing", "Conflict", "Poetics", and "Coherence" use target "Scene" and do not load external context.
    // "Character Awareness" currently only supports target "Plot Thread".
    // "Reader Awareness" currently supports targets "Character", "Plot Thread", and "Arc".
    "evaluations": [
      ["Relevance", "Character"],
      ["Relevance", "Plot Thread"],
      ["Relevance", "Story Engine"],
      ["Relevance", "Arc"],
      ["Tension", "Character"],
      ["Tension", "Plot Thread"],
      ["Tension", "Story Engine"],
      ["Tension", "Arc"],
      ["Resolution", "Character"],
      ["Resolution", "Plot Thread"],
      ["Resolution", "Story Engine"],
      ["Resolution", "Arc"],
      ["Pacing", "Scene"],
      ["Conflict", "Scene"],
      ["Poetics", "Scene"],
      ["Coherence", "Scene"],
      ["Character Awareness", "Plot Thread"],
      ["Reader Awareness", "Character"],
      ["Reader Awareness", "Plot Thread"],
      ["Reader Awareness", "Arc"]
    ]
  }
}
