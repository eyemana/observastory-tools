{
  // Ollama generate endpoint used by evaluators/evaluate-scene.mjs.
  // Typical local value: "http://localhost:11434/api/generate".
  "ollamaUrl": "http://localhost:11434/api/generate",

  // Ollama model name to use for every evaluator call.
  // Example options depend on what is installed locally: "qwen2.5:7b", "llama3.1:8b", etc.
  "model": "qwen2.5:7b",

  "awareness": {
    // Controls whether awareness evaluators store generated rationale text.
    // "off": store only bounded numeric fields.
    // "extractive": store only exact evidence excerpts copied from supplied notes/scenes/definitions.
    // "paraphrase": store one tight model-written rationale sentence.
    "rationaleMode": "paraphrase",

    // Source buckets allowed for extractive evidence validation.
    // Available values: "scene", "definitions", "priorScenes".
    "rationaleSources": ["scene", "definitions", "priorScenes"]
  },

  "story": {
    // Root folder for the book/story inside the Obsidian vault.
    // Move this when you start a different tutorial or project.
    "root": "Example Book - A Ledger for Maribel Leigh",

    // Folder names are relative to story.root unless an absolute path is supplied.
    // The defaults are intentionally plain so the vault stays easy to teach.
    "folders": {
      "scenes": "Scenes",
      "characters": "Characters",
      "plotThreads": "plot threads",
      "storyEngines": "story engines",
      "arcs": "Arcs",
      "metrics": "Metrics",
      "reports": "Reports",
      "notes": "Notes"
    },

    // Entity types normalize writer-facing folders into evaluator targets.
    // folderKeys refer to story.folders entries. Use paths for explicit folders
    // when a project spreads one entity type across multiple places.
    "entityTypes": {
      "characters": {
        "target": "character",
        "folderKeys": ["characters"],
        "label": "character",
        "pluralLabel": "characters"
      },
      "plotThreads": {
        "target": "plot thread",
        "folderKeys": ["plotThreads"],
        "label": "plot thread",
        "pluralLabel": "plot threads"
      },
      "storyEngines": {
        "target": "story engine",
        "folderKeys": ["storyEngines"],
        "label": "story engine",
        "pluralLabel": "story engines"
      },
      "arcs": {
        "target": "arc",
        "folderKeys": ["arcs"],
        "label": "arc",
        "pluralLabel": "arcs"
      }
    }
  },

  // Scene lifecycle is author-controlled per scene with frontmatter status.
  // Missing status defaults to draft. scratch and archived are excluded from
  // normal evaluation and Truth Ledger processing.
  "sceneLifecycle": {
    "defaultStatus": "draft",
    "excludedStatuses": ["scratch", "archived"]
  },

  "calibration": {
    "modes": {
      "draft": {
        "guidance": "Scene lifecycle status: draft. The author has intentionally marked this scene as working material. It may contain notes, placeholders, outline fragments, paraphrase, lists, and links that indicate intended entities or relationships. Treat explicit Obsidian links as strong author intent signals for relevant entity and relationship observations, but keep polish-facing displayed scores conservative where caps are configured.",
        "scoreCeilings": {
          "pacing": 7,
          "poetics": 6,
          "coherence": 6
        }
      },
      "live": {
        "guidance": "Scene lifecycle status: live. Treat this as prose intended to be part of the book. Do not apply protective draft dampening. Visible scaffolding, TODOs, placeholders, outline fragments, paraphrase, and loose notes should lower the appropriate craft scores and raise Scaffolding.",
        "scoreCeilings": {}
      },
      "scratch": {
        "guidance": "Scene lifecycle status: scratch. Scratch scenes are excluded before evaluator prompts are built.",
        "scoreCeilings": {}
      },
      "archived": {
        "guidance": "Scene lifecycle status: archived. Archived scenes are excluded before evaluator prompts are built.",
        "scoreCeilings": {}
      }
    }
  },

  "standardMetrics": {
    "default": {
      // Controls whether non-awareness evaluators store rationale text.
      // "off": store only bounded numeric fields.
      // "extractive": store only exact evidence excerpts copied from supplied scene/definitions.
      // "paraphrase": store one tight model-written rationale sentence.
      "rationaleMode": "paraphrase",

      // Source buckets allowed for extractive evidence validation.
      // Available values: "scene", "definitions".
      "rationaleSources": ["scene", "definitions"],

      // Frontmatter field used for paraphrased rationale on standard metric score objects.
      // Existing reports expect "sceneRationale".
      "rationaleField": "sceneRationale"
    },

    // Per-metric wording for the configured rationale field.
    // These labels are prompt guidance only; the JSON field is controlled by rationaleField above.
    "metrics": {
      "Relevance": { "rationaleType": "relevance rationale" },
      "Tension": { "rationaleType": "tension rationale" },
      "Resolution": { "rationaleType": "resolution rationale" },
      "Pacing": { "rationaleType": "pacing rationale" },
      "Conflict": { "rationaleType": "conflict rationale" },
      "Poetics": { "rationaleType": "poetics rationale" },
      "Coherence": { "rationaleType": "coherence rationale" },
      "Scaffolding": { "rationaleType": "scaffolding rationale" }
    }
  },

  "truthLedger": {
    // Folder keys to scan for authored anchors and inferred support.
    // These names come from story.folders above, keeping the tutorial paths in one place.
    "folders": ["notes", "arcs", "storyEngines", "plotThreads", "characters", "scenes"],

    // Generated JSON index used by reports and awareness evaluator grounding.
    // Relative paths are resolved from the observastory-tools folder.
    "outputPath": ".index/truth-ledger.json",

    // Per-note generated partial cache. Unchanged notes reuse cached authored/inferred output.
    // Relative paths are resolved from observastory-tools.
    "cachePath": ".queue/truth-ledger-cache.json",

    "inference": {
      // When enabled, the collector asks the local LLM to infer lower-authority
      // support claims from scanned notes. These are written separately from
      // authored anchors as inferredClaims and shown in the Truth Ledger report.
      "enabled": true,

      // Per-note cap for inferred claims.
      "maxClaimsPerNote": 5,

      // 0-10 minimum confidence required to keep an inferred claim.
      "minConfidence": 6
    }
  },

  "chronology": {
    // Folder keys to scan for scene chronology metadata.
    // These names come from story.folders above.
    "folders": ["scenes"],

    // Generated chronology metadata is written under scene frontmatter ai.chronology.
    // The author maintains chronology_label and chronology_value.
    "generatedPath": "ai.chronology",

    // Sort values are generated as signed millisecond strings so deep time remains sortable.
    "sortUnit": "ms"
  },

  "evaluation": {
    // Named profiles let you switch evaluation scope without editing many notes.
    // Element filters control which character, plot thread, story engine, and arc
    // notes are eligible for scoring. Scene filters control which scenes are queued.
    "defaultProfile": "default",

    // These defaults include notes unless status or tags exclude them. Missing scene status is treated as draft.
    // Put tags: [no-evaluate] on a scene to keep it out of normal queue-all runs.
    // Include/exclude conflicts are configuration errors; neither side overrides the other.
    "elementFilters": {
      "includeStatuses": [],
      "excludeStatuses": ["scratch", "archived", "inactive"],
      "includeTags": [],
      "excludeTags": ["no-evaluate", "exclude-evaluation"]
    },

    "sceneFilters": {
      "includeStatuses": [],
      "excludeStatuses": ["scratch", "archived", "inactive"],
      "includeTags": [],
      "excludeTags": ["no-evaluate", "exclude-evaluation"]
    },

    // Example experiment profile:
    // "harborExperiment": {
    //   "elementFilters": { "includeTags": ["harbor-experiment"] },
    //   "sceneFilters": { "includeTags": ["harbor-experiment"] }
    // }
    "profiles": {
      "default": {}
    }
  },

  "evaluationCache": {
    // When enabled, scene evaluators store an input fingerprint for each
    // metric/target axis and skip unchanged reruns without calling the model
    // or rewriting the scene file. Use --force on enqueue-scene-evaluations.mjs
    // or evaluate-scene.mjs to intentionally rerun unchanged evaluations.
    "enabled": true
  },

  "scheduler": {
    // How jobs are picked up after Templater queues them.
    // "manual": Templater queues a job and starts a worker that drains the queue, then exits.
    // "background": Templater only queues jobs; a separately started --watch worker polls for work.
    "mode": "manual",

    // Directory for job files, logs, cancel markers, and the worker lock.
    // Relative paths are resolved from the observastory-tools folder; absolute paths are allowed.
    "queueDir": ".queue",

    // Delay between evaluator calls and Truth Ledger note crawls.
    // Increase this if Ollama or the machine is overloaded.
    // Lower values run faster but put more pressure on local resources.
    "throttleMs": 1000,

    // Background-mode poll interval. Only used by worker.mjs --watch / scheduler mode "background".
    "pollIntervalMs": 30000,

    // In manual mode, start a detached worker from the queueing Templater commands.
    // Set false if you want Templater to queue only and you will run worker.mjs --drain yourself.
    "launchWorkerFromTemplater": true,

    // Show periodic Obsidian notices while the queued job is running.
    // Set false if you prefer to watch .queue/logs or job JSON files directly.
    "monitorFromTemplater": true,

    // How often Obsidian checks job progress and shows a notice while monitoring.
    // Notices are only shown when the message changes.
    "statusNoticeIntervalMs": 5000,

    // Safety cap for Obsidian-side monitoring. The worker keeps running after this; notices stop.
    "statusNoticeMaxMinutes": 240,

    // Node executable used by Templater when it shells out to scheduler scripts.
    // Use a full path here if Obsidian cannot find "node" on PATH.
    "nodePath": "node",

    "backgroundSceneScan": {
      // In background mode, the worker scans eligible scene notes and queues
      // only scenes whose author-owned input changed since the last scan.
      // The fingerprint ignores ai frontmatter so evaluator writes do not
      // trigger another evaluation loop.
      "enabled": true,

      // Wait this long after detecting a changed scene before queueing it.
      // This keeps active Obsidian edits from hyper-triggering evaluations.
      "debounceMs": 5000,

      // On the first background run, write a baseline instead of queueing
      // every existing scene. Use Queue-All-Scenes-for-Evaluation for an
      // intentional full pass.
      "baselineOnFirstRun": true,

      // Relative paths are resolved from observastory-tools.
      "fingerprintPath": ".queue/background-scene-fingerprints.json"
    },

    // What Storyboard should do after saving a changed tile order.
    // "manual": only save chapter_order and scene_order; use Queue-Reader-Awareness manually.
    // "ask": ask whether to queue reader awareness after saving order.
    // "auto": queue reader awareness immediately after saving order.
    "storyboardReaderAwarenessAfterReorder": "ask",

    // Evaluations used by the dedicated reader awareness trigger.
    // Full scene evaluation queueing also includes these entries as part of scheduler.evaluations below.
    "readerAwarenessEvaluations": [
      ["reader awareness", "character"],
      ["reader awareness", "plot thread"],
      ["reader awareness", "arc"]
    ],

    // Evaluations to run for each scene, in order.
    // Format: [metric, target].
    // Metric options: "relevance", "tension", "resolution", "pacing", "conflict", "poetics",
    // "coherence", "scaffolding", "character awareness", "reader awareness".
    // Target options: "character", "plot thread", "story engine", "arc", "scene".
    // "pacing", "conflict", "poetics", "coherence", and "scaffolding" use target "scene" and do not load external context.
    // "character awareness" currently only supports target "plot thread".
    // "reader awareness" currently supports targets "character", "plot thread", and "arc".
    "evaluations": [
      ["relevance", "character"],
      ["relevance", "plot thread"],
      ["relevance", "story engine"],
      ["relevance", "arc"],
      ["tension", "character"],
      ["tension", "plot thread"],
      ["tension", "story engine"],
      ["tension", "arc"],
      ["resolution", "character"],
      ["resolution", "plot thread"],
      ["resolution", "story engine"],
      ["resolution", "arc"],
      ["pacing", "scene"],
      ["conflict", "scene"],
      ["poetics", "scene"],
      ["coherence", "scene"],
      ["scaffolding", "scene"],
      ["character awareness", "plot thread"],
      ["reader awareness", "character"],
      ["reader awareness", "plot thread"],
      ["reader awareness", "arc"]
    ]
  }
}
